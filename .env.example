# AURA HQ — Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Google OAuth (for Gmail + Calendar tool integrations)
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/connect/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connect/google/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend (FastAPI — Python)
# In development: http://localhost:8000
# In production: your deployed FastAPI service URL
BACKEND_URL=http://localhost:8000
